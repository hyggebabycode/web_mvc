@model BTL_WEB.Models.ViewModels.UserDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<section class="ftco-section bg-light user-dashboard-page">
    <div class="container-fluid px-lg-5">
        <div class="row">
            <div class="col-lg-3 mb-3">
                <div class="dashboard-sidebar shadow-sm">
                    <h5 class="mb-4">PetCareHub</h5>
                    <a href="#" class="active">Tổng quan</a>
                    <a href="#my-pets">Thú cưng của tôi</a>
                    <a href="#upcoming-appointments">Lịch hẹn của tôi</a>
                    <a href="#">Lịch sử thanh toán</a>
                    <a asp-controller="Home" asp-action="Profile">Hồ sơ cá nhân</a>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="dashboard-content shadow-sm">
                    <div class="dashboard-header">
                        <div>
                            <h4 class="mb-0">Xin chào, @Model.FullName</h4>
                            <small class="text-muted">@Model.Email</small>
                        </div>
                        <div class="dashboard-header-right">
                            <span class="notify-badge"><i class="fa fa-bell"></i> 2</span>
                            <div class="avatar-circle">@Model.FullName.Substring(0, 1).ToUpper()</div>
                        </div>
                    </div>

                    <div id="my-pets" class="mt-4">
                        <h5 class="mb-3">Thú cưng của tôi</h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered bg-white mb-0">
                                <thead>
                                    <tr>
                                        <th>PetID</th>
                                        <th>Tên</th>
                                        <th>Loài</th>
                                        <th>Giống</th>
                                        <th>Trạng thái</th>
                                        <th>Adoption</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Pets.Count == 0)
                                    {
                                        <tr><td colspan="6" class="text-center text-muted">Chưa có thú cưng nào.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var pet in Model.Pets)
                                        {
                                            <tr>
                                                <td>@pet.PetId</td>
                                                <td>@pet.Name</td>
                                                <td>@pet.Species</td>
                                                <td>@pet.Breed</td>
                                                <td><span class="badge @StatusDisplay.BadgeClass(pet.Status)">@StatusDisplay.Label(pet.Status)</span></td>
                                                <td><span class="badge @StatusDisplay.BadgeClass(pet.AdoptionStatus)">@StatusDisplay.Label(pet.AdoptionStatus)</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div id="upcoming-appointments" class="mt-4">
                        <h5 class="mb-3">Lịch hẹn sắp tới</h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered bg-white mb-0">
                                <thead>
                                    <tr>
                                        <th>Ngày giờ</th>
                                        <th>Thú cưng</th>
                                        <th>Dịch vụ</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.UpcomingAppointments.Count == 0)
                                    {
                                        <tr><td colspan="4" class="text-center text-muted">Không có lịch hẹn sắp tới.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var item in Model.UpcomingAppointments)
                                        {
                                            <tr>
                                                <td>@item.AppointmentDateTime.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>@item.PetName</td>
                                                <td>@item.ServiceName</td>
                                                <td><span class="badge @StatusDisplay.BadgeClass(item.Status)">@StatusDisplay.Label(item.Status)</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .user-dashboard-page .dashboard-sidebar {
        background: #146c2e;
        color: #fff;
        border-radius: 12px;
        padding: 20px;
        min-height: 100%;
    }

    .dashboard-sidebar a {
        display: block;
        color: #dff3e4;
        padding: 10px 12px;
        border-radius: 8px;
        margin-bottom: 6px;
        text-decoration: none;
    }

    .dashboard-sidebar a.active,
    .dashboard-sidebar a:hover {
        background: rgba(255, 255, 255, .14);
        color: #fff;
    }

    .dashboard-content {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
    }

    .dashboard-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #edf1ed;
        padding-bottom: 14px;
    }

    .dashboard-header-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #28a745;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    .notify-badge {
        background: #f3f6f3;
        border: 1px solid #dce6dd;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: .9rem;
    }
</style>
