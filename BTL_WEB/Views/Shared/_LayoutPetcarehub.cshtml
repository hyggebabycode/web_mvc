@using BTL_WEB.Helpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - PetCareHub</title>

    <link href="https://fonts.googleapis.com/css?family=Montserrat:200,300,400,500,600,700,800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/animate.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/owl.carousel.min.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/owl.theme.default.min.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/magnific-popup.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/bootstrap-datepicker.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/jquery.timepicker.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/flaticon.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/style.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .petcare-nav-main .nav-link,
        .petcare-nav-main .dropdown-toggle {
            white-space: nowrap;
        }

        .petcare-nav-main .user-nav-search {
            display: flex;
            align-items: center;
            flex-wrap: nowrap;
            gap: .4rem;
            margin-bottom: 0;
        }

        .petcare-nav-main .user-nav-search .form-control {
            min-width: 150px;
            height: 34px;
            border-radius: 999px;
            margin-right: 0;
            width: auto;
            flex: 1 1 auto;
        }

        .petcare-nav-main .user-nav-search .btn {
            border-radius: 999px;
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
        }

        .public-avatar-fallback {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #00bd56;
            color: #fff;
            font-weight: 700;
        }

        @@media (min-width: 992px) {
            .petcare-nav-main .navbar-nav > .nav-item > .nav-link {
                padding-left: .65rem;
                padding-right: .65rem;
            }
        }
    </style>
</head>
<body>
    @{
        var isLoggedIn = Context.User.Identity?.IsAuthenticated == true;
        var displayName = Context.User.FindFirst(ClaimNames.FullName)?.Value ?? Context.User.Identity?.Name ?? "Khách";
        var avatarInitial = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName.Trim().Substring(0, 1).ToUpper();
    }

    <div class="wrap">
        <div class="container">
            <div class="row">
                <div class="col-md-6 d-flex align-items-center">
                    <p class="mb-0 phone pl-md-2">
                        <a href="tel:+001234567" class="mr-2"><span class="fa fa-phone mr-1"></span> +00 1234 567</a>
                        <a href="mailto:youremail@email.com"><span class="fa fa-paper-plane mr-1"></span> youremail@email.com</a>
                    </p>
                </div>
                <div class="col-md-6 d-flex justify-content-md-end">
                    <div class="social-media">
                        <p class="mb-0 d-flex">
                            <a href="#" class="d-flex align-items-center justify-content-center"><span class="fa fa-facebook"><i class="sr-only">Facebook</i></span></a>
                            <a href="#" class="d-flex align-items-center justify-content-center"><span class="fa fa-twitter"><i class="sr-only">Twitter</i></span></a>
                            <a href="#" class="d-flex align-items-center justify-content-center"><span class="fa fa-instagram"><i class="sr-only">Instagram</i></span></a>
                            <a href="#" class="d-flex align-items-center justify-content-center"><span class="fa fa-dribbble"><i class="sr-only">Dribbble</i></span></a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark ftco_navbar bg-dark ftco-navbar-light petcare-nav-main" id="ftco-navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index"><span class="flaticon-pawprint-1 mr-2"></span>PetCareHub</a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#ftco-nav" aria-controls="ftco-nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="fa fa-bars"></span> Menu
            </button>
            <div class="collapse navbar-collapse" id="ftco-nav">
                <ul class="navbar-nav mr-auto align-items-lg-center">
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : string.Empty)">
                        <a asp-controller="Home" asp-action="Index" class="nav-link">Tổng quan</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Services" ? "active" : string.Empty)">
                        <a asp-controller="Services" asp-action="Catalog" class="nav-link">Dịch vụ</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Management" && ViewContext.RouteData.Values["action"]?.ToString() == "Pets" ? "active" : string.Empty)">
                        <a asp-controller="Management" asp-action="Pets" class="nav-link">Thú cưng</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Management" && ViewContext.RouteData.Values["action"]?.ToString() == "Appointments" ? "active" : string.Empty)">
                        <a asp-controller="Management" asp-action="Appointments" class="nav-link">Lịch hẹn</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : string.Empty)">
                        <a asp-controller="Home" asp-action="Profile" class="nav-link">Hồ sơ cá nhân</a>
                    </li>
                </ul>

                <form class="form-inline user-nav-search mx-lg-3 my-2 my-lg-0" method="get" asp-controller="Management" asp-action="Pets">
                    <input type="search" class="form-control form-control-sm" name="searchTerm" placeholder="Tìm thú cưng" aria-label="Tìm thú cưng" />
                    <button class="btn btn-primary btn-sm" type="submit" aria-label="Tìm thú cưng">
                        <span class="fa fa-search"></span>
                    </button>
                </form>

                <ul class="navbar-nav align-items-lg-center ml-lg-auto">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle d-flex align-items-center" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <span class="public-avatar-fallback mr-2">@avatarInitial</span>
                                <span class="text-nowrap">@displayName</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right">
                                <a class="dropdown-item" asp-controller="Home" asp-action="Dashboard">Tổng quan</a>
                                <a class="dropdown-item" asp-controller="Home" asp-action="Profile">Hồ sơ cá nhân</a>
                                <div class="dropdown-divider"></div>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="dropdown-item">Đăng xuất</button>
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Login" ? "active" : string.Empty)">
                            <a asp-controller="Account" asp-action="Login" class="nav-link text-nowrap">Đăng nhập</a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Register" ? "active" : string.Empty)">
                            <a asp-controller="Account" asp-action="Register" class="nav-link text-nowrap">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <script src="~/LayoutPetcare/js/jquery.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery-migrate-3.0.1.min.js"></script>
    <script src="~/LayoutPetcare/js/popper.min.js"></script>
    <script src="~/LayoutPetcare/js/bootstrap.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.easing.1.3.js"></script>
    <script src="~/LayoutPetcare/js/jquery.waypoints.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.stellar.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.animateNumber.min.js"></script>
    <script src="~/LayoutPetcare/js/bootstrap-datepicker.js"></script>
    <script src="~/LayoutPetcare/js/jquery.timepicker.min.js"></script>
    <script src="~/LayoutPetcare/js/owl.carousel.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.magnific-popup.min.js"></script>
    <script src="~/LayoutPetcare/js/scrollax.min.js"></script>
    <script src="~/LayoutPetcare/js/main.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
