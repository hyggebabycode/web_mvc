@using Microsoft.AspNetCore.Http
@using BTL_WEB.Helpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - PetCareHub</title>

    <link href="https://fonts.googleapis.com/css?family=Montserrat:200,300,400,500,600,700,800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/animate.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/owl.carousel.min.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/owl.theme.default.min.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/magnific-popup.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/bootstrap-datepicker.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/jquery.timepicker.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/flaticon.css" />
    <link rel="stylesheet" href="~/LayoutPetcare/css/style.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .user-main-nav .nav-link,
        .user-main-nav .dropdown-toggle {
            white-space: nowrap;
        }

        .user-main-nav .user-search {
            margin-bottom: 0;
        }

        .user-main-nav .user-search .input-group {
            flex-wrap: nowrap;
        }

        .user-main-nav .user-search .form-control {
            min-width: 170px;
            height: 36px;
            border-radius: 999px 0 0 999px;
            border-right: 0;
            margin: 0;
        }

        .user-main-nav .user-search .input-group-append .btn {
            width: 40px;
            height: 36px;
            border-radius: 0 999px 999px 0;
            margin: 0;
            padding: 0;
            line-height: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .user-avatar-img,
        .user-avatar-fallback {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #d8f0de;
        }

        .user-avatar-fallback {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #28a745;
            color: #fff;
            font-weight: 700;
            font-size: .9rem;
        }
    </style>
</head>
<body>
    @{
        var isLoggedIn = Context.User.Identity?.IsAuthenticated == true;
        var displayName = Context.User.FindFirst(ClaimNames.FullName)?.Value ?? Context.User.Identity?.Name ?? "Khách";
        var avatarUrl = Context.Session.GetString("ProfileAvatarUrl");
        var avatarInitial = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName.Trim().Substring(0, 1).ToUpper();
        var isStaffOrAdmin = Context.User.IsInRole(RoleNames.Admin) || Context.User.IsInRole(RoleNames.Staff);
    }

    <nav class="navbar navbar-expand-lg navbar-dark ftco_navbar bg-dark ftco-navbar-light user-main-nav" id="ftco-navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index"><span class="flaticon-pawprint-1 mr-2"></span>PetCareHub</a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#ftco-nav" aria-controls="ftco-nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="fa fa-bars"></span> Menu
            </button>
            <div class="collapse navbar-collapse" id="ftco-nav">
                <ul class="navbar-nav mr-auto align-items-lg-center">
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Services" ? "active" : string.Empty)">
                        <a asp-controller="Services" asp-action="Catalog" class="nav-link">Dịch vụ</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Pets" ? "active" : string.Empty)">
                        <a asp-controller="Management" asp-action="Pets" class="nav-link">Thú cưng</a>
                    </li>
                    @if (isLoggedIn && isStaffOrAdmin)
                    {
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "System" ? "active" : string.Empty)">
                            <a asp-controller="Management" asp-action="System" class="nav-link">Quản trị</a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Appointments" ? "active" : string.Empty)">
                            <a asp-controller="Management" asp-action="Appointments" class="nav-link">QL lịch hẹn</a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Adoptions" ? "active" : string.Empty)">
                            <a asp-controller="Management" asp-action="Adoptions" class="nav-link">QL nhận nuôi</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Appointments" ? "active" : string.Empty)">
                            <a asp-controller="Management" asp-action="Appointments" class="nav-link">Lịch hẹn</a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : string.Empty)">
                            <a asp-controller="Home" asp-action="Profile" class="nav-link">Hồ sơ cá nhân</a>
                        </li>
                    }
                </ul>

                <form class="form-inline user-search mx-lg-3 my-2 my-lg-0" method="get" asp-controller="Management" asp-action="Pets">
                    <div class="input-group input-group-sm">
                        <input type="search" class="form-control" name="searchTerm" placeholder="Tìm thú cưng" aria-label="Tìm thú cưng" />
                        <div class="input-group-append">
                            <button class="btn btn-primary" type="submit" aria-label="Tìm thú cưng">
                                <span class="fa fa-search"></span>
                            </button>
                        </div>
                    </div>
                </form>

                <ul class="navbar-nav align-items-lg-center ml-lg-auto">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle d-flex align-items-center" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                @if (!string.IsNullOrWhiteSpace(avatarUrl))
                                {
                                    <img src="@avatarUrl" alt="Avatar" class="user-avatar-img mr-2" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
                                    <span class="user-avatar-fallback mr-2" style="display:none;">@avatarInitial</span>
                                }
                                else
                                {
                                    <span class="user-avatar-fallback mr-2">@avatarInitial</span>
                                }
                                <span class="text-nowrap">@displayName</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right">
                                <a class="dropdown-item" asp-controller="Services" asp-action="Catalog">Dịch vụ</a>
                                <a class="dropdown-item" asp-controller="Management" asp-action="Pets">Thú cưng</a>
                                @if (isStaffOrAdmin)
                                {
                                    <a class="dropdown-item" asp-controller="Management" asp-action="System">Trang quản trị</a>
                                    <a class="dropdown-item" asp-controller="Management" asp-action="Appointments">Quản lý lịch hẹn</a>
                                    <a class="dropdown-item" asp-controller="Management" asp-action="Adoptions">Quản lý nhận nuôi</a>
                                }
                                else
                                {
                                    <a class="dropdown-item" asp-controller="Management" asp-action="Appointments">Lịch hẹn của tôi</a>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="Dashboard">Tổng quan</a>
                                }
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-controller="Home" asp-action="Profile">Chỉnh sửa hồ sơ</a>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="dropdown-item">Đăng xuất</button>
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a asp-controller="Account" asp-action="Login" class="nav-link">Đăng nhập</a></li>
                        <li class="nav-item"><a asp-controller="Account" asp-action="Register" class="nav-link">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <script src="~/LayoutPetcare/js/jquery.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery-migrate-3.0.1.min.js"></script>
    <script src="~/LayoutPetcare/js/popper.min.js"></script>
    <script src="~/LayoutPetcare/js/bootstrap.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.easing.1.3.js"></script>
    <script src="~/LayoutPetcare/js/jquery.waypoints.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.stellar.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.animateNumber.min.js"></script>
    <script src="~/LayoutPetcare/js/bootstrap-datepicker.js"></script>
    <script src="~/LayoutPetcare/js/jquery.timepicker.min.js"></script>
    <script src="~/LayoutPetcare/js/owl.carousel.min.js"></script>
    <script src="~/LayoutPetcare/js/jquery.magnific-popup.min.js"></script>
    <script src="~/LayoutPetcare/js/scrollax.min.js"></script>
    <script src="~/LayoutPetcare/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
